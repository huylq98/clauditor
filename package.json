{
  "name": "clauditor",
  "version": "0.1.0",
  "description": "Desktop manager for multiple Claude Code sessions",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "body-parser": "^1.20.3",
    "express": "^4.21.2",
    "@lydell/node-pty": "^1.1.0",
    "uuid": "^11.0.5",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "dev.clauditor.app",
    "productName": "Clauditor",
    "files": ["src/**/*", "assets/**/*", "package.json"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
