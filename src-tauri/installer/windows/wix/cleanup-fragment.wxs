<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <!-- Default: preserve user data on uninstall. Enterprise users can pass
         PURGE_DATA=1 on the msiexec command line to wipe %APPDATA%\dev.clauditor.app. -->
    <Property Id="PURGE_DATA" Value="0" Secure="yes" />

    <!-- Two CustomActions: one for each mode. Impersonate="yes" so the child
         process inherits the user's HOME / APPDATA, not the elevated SYSTEM env. -->
    <CustomAction Id="ClauditorCleanupPreserve"
                  Directory="INSTALLDIR"
                  ExeCommand="[INSTALLDIR]clauditor.exe --cleanup"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />
    <CustomAction Id="ClauditorCleanupPurge"
                  Directory="INSTALLDIR"
                  ExeCommand="[INSTALLDIR]clauditor.exe --cleanup --purge"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- Run on full uninstall only (REMOVE=ALL), never on upgrade or repair.
           Sequenced Before="RemoveFiles" so clauditor.exe still exists when invoked. -->
      <Custom Action="ClauditorCleanupPreserve" Before="RemoveFiles">
        <![CDATA[REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND PURGE_DATA="0"]]>
      </Custom>
      <Custom Action="ClauditorCleanupPurge" Before="RemoveFiles">
        <![CDATA[REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE AND PURGE_DATA="1"]]>
      </Custom>
    </InstallExecuteSequence>
  </Fragment>
</Wix>
