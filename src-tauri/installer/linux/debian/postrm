#!/bin/sh
# Clauditor Debian postrm script.
# Invoked by dpkg after file removal. `$1` is the action: remove, purge, upgrade, etc.
# Runs as root. We switch back to the invoking user's HOME to clean up hooks.

set -e

USER_HOME=""
if [ -n "$SUDO_USER" ] && [ "$SUDO_USER" != "root" ]; then
  USER_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
fi
[ -z "$USER_HOME" ] && USER_HOME="$HOME"
[ -z "$USER_HOME" ] && USER_HOME="/root"

SETTINGS="$USER_HOME/.claude/settings.json"
HOOK_SCRIPT="$USER_HOME/.claude/clauditor-hook.sh"
APP_DATA="$USER_HOME/.local/share/dev.clauditor.app"

clean_hooks() {
  # postrm runs after binary removal, so we can't shell out to clauditor.
  # Use python3 which is guaranteed on Debian/Ubuntu base systems.
  [ ! -f "$SETTINGS" ] && return 0
  python3 - "$SETTINGS" <<'PY' || true
import json, sys
p = sys.argv[1]
try:
    with open(p) as f: s = json.load(f)
except Exception:
    sys.exit(0)
hooks = s.get("hooks")
if isinstance(hooks, dict):
    for ev in list(hooks.keys()):
        arr = hooks.get(ev)
        if isinstance(arr, list):
            arr[:] = [g for g in arr if not (isinstance(g, dict) and g.get("_clauditor") is True)]
            if not arr: del hooks[ev]
    if not hooks: del s["hooks"]
with open(p, "w") as f: json.dump(s, f, indent=2)
PY
  [ -f "$HOOK_SCRIPT" ] && rm -f "$HOOK_SCRIPT"
  return 0
}

purge_app_data() {
  [ -d "$APP_DATA" ] && rm -rf "$APP_DATA"
  return 0
}

case "$1" in
  remove)
    clean_hooks
    ;;
  purge)
    clean_hooks
    purge_app_data
    ;;
  upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
    # No action — preserve everything during upgrades.
    ;;
esac

exit 0
